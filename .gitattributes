# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# C source files
*.c     text eol=lf diff=cpp
*.h     text eol=lf diff=cpp

# CMake
CMakeLists.txt  text eol=lf
*.cmake         text eol=lf

# Documentation & config
*.md        text eol=lf diff=markdown
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf

# Linker scripts
*.ld        text eol=lf

# Shell scripts
*.sh        text eol=lf

# Binary files — Git must never diff or mangle these
*.elf       binary
*.bin       binary
*.hex       binary
*.srec      binary
*.a         binary
*.o         binary
*.png       binary
*.jpg       binary
*.pdf       binary
